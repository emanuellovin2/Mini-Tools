{"nodes": [{"id": "spec", "label": "SPEC.md", "file_type": "document", "source_file": "SPEC.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "platform", "label": "[PLATFORM] Marketplace", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a71", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "role_admin", "label": "Admin role", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a72", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "role_vendor", "label": "Vendor role", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a72", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "role_buyer", "label": "Buyer role", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a72", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "role_reseller", "label": "Reseller role (Phase 2)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a72, \u00a74", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "role_escalation_guard", "label": "Role escalation guard (RLS)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a72, \u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: a user must never change their own role; profiles UPDATE policy enforces WITH CHECK new role = old role; role/Connect/customer columns written only by service role"}, {"id": "hybrid_pricing", "label": "Hybrid pricing tiers", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a73", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: tiers evaluated in integer cents; cut stored as basis points to avoid floats; tier frozen per period so closed vendor_billing rows are never re-tiered"}, {"id": "tier_1", "label": "Tier 1 (<$500, 2000 bps, $0 fee)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a73", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "tier_2", "label": "Tier 2 ($500-$2000, 1000 bps, $49 fee)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a73", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "tier_3", "label": "Tier 3 (>=$2000, 500 bps, $99 fee)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a73", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "default_tier1_helper", "label": "Default Tier 1 cut_bps helper", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: shared helper returns Tier 1 defaults (cut_bps=2000, platform_fee_cents=0) when no vendor_billing row exists; prevents crashes and never defaults to 0% cut for new vendors"}, {"id": "cash_basis_refund", "label": "Refund cash-basis accounting", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a73", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: refunds/dispute losses subtracted from the month they OCCUR, not the original charge month; keeps tier computation forward-only and never re-tiers a closed vendor_billing period; gross floored at 0"}, {"id": "separate_charges_transfers", "label": "Separate Charges & Transfers", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a711", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: required because a single charge must fund multiple recipients (vendor + reseller) and reversals must be precise per recipient; destination charges insufficient"}, {"id": "anon_token_model", "label": "Anonymous token access model", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a76", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: anti-poaching core; vendors never see buyer email/name/card; platform as constant source of customers replaces heavy legal contract"}, {"id": "anon_user_id_reuse", "label": "anon_user_id reuse-on-resub logic", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a76", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: stable per (buyer_id, app_id) across resubscriptions to preserve vendor's in-app history; no UNIQUE constraint on subscriptions.anon_user_id since same id intentionally repeats across rows; 16-byte CSPRNG makes collisions negligible (~2^-128)"}, {"id": "jwks_endpoint", "label": "JWKS endpoint + RS256 JWT", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a75, \u00a76", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: kid header + public JWKS so keys can rotate without breaking vendors mid-flight"}, {"id": "verify_api", "label": "/api/verify endpoint", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a76", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: re-reads live subscription status from DB (token's active is a 5-min snapshot); returns no PII; rate-limited; allows 30s clockTolerance for clock skew"}, {"id": "schema_profiles", "label": "profiles table", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "display_name", "label": "profiles.display_name", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: only profile field exposable to vendors/marketplace; vendor's public name + reseller's payout name; nullable so buyers may leave null"}, {"id": "schema_apps", "label": "apps table", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "schema_subscriptions", "label": "subscriptions table", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "schema_vendor_billing", "label": "vendor_billing table", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "schema_webhook_events", "label": "webhook_events table", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "schema_audit_log", "label": "audit_log table", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: append-only \u2014 insert by service role, read by admin, never updated/deleted"}, {"id": "vendor_subscription_stats", "label": "vendor_subscription_stats view", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: anti-poaching boundary \u2014 vendors get no direct read on subscriptions; view exposes only app_id, anon_user_id, status, price_cents, current_period_end for their own apps"}, {"id": "schema_referrals", "label": "referrals + referral_attributions (Phase 2)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "state_machine", "label": "Status \u2192 access state machine", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: SINGLE shared pure function used by webhook handler AND /api/verify; unknown Stripe status MUST throw rather than silently default to active=false so audit_log captures unknown state"}, {"id": "status_incomplete_expired", "label": "status: incomplete_expired (access=false)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "status_trialing", "label": "status: trialing (access=true)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "status_paused", "label": "status: paused (access=false)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "webhook_deauthorized", "label": "account.application.deauthorized webhook", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78, \u00a711", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: sets charges_enabled=false + payouts_enabled=false; marketplace listing filter auto-hides their approved apps; active subs continue billing until manual admin action (intentional, not a bug); new subs blocked by listing filter"}, {"id": "webhook_account_updated", "label": "account.updated webhook", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a711", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "churn_detection", "label": "Churn detection job", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: monthly job flags vendors whose cancellation rate exceeds CHURN_ALERT_THRESHOLD_BPS (possible poaching / in-app email capture); alert admin via Resend"}, {"id": "anti_poaching", "label": "Anti-poaching data boundary", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a76, \u00a77", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: vendors get NO path to subscriptions.buyer_id or any buyer PII; the defensibility, replacing the need for a heavy legal contract"}, {"id": "reseller_split", "label": "3-way split (70/10/20)", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a74", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: vendor 70 / platform 10 / reseller 20 replaces standard tier cut for reseller-attributed subscriptions; flat tier fee still applies"}, {"id": "refund_reverse_transfer", "label": "Refund/dispute reverse_transfer", "file_type": "concept", "source_file": "SPEC.md", "source_location": "\u00a78, \u00a711", "source_url": null, "captured_at": null, "author": null, "contributor": "rationale: on charge.refunded / dispute, reverse matching transfers so vendor and reseller don't keep funds for returned/charged-back payments; handle negative balances"}], "edges": [{"source": "spec", "target": "engineering", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md", "source_location": "\u00a712", "weight": 1.0}, {"source": "platform", "target": "role_admin", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md", "source_location": "\u00a72", "weight": 1.0}, {"source": "platform", "target": "role_vendor", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "SPEC.md", "source_location": "\u00a72", "weight": 1.0}, {"source": "platform", "target": "role_buyer", "relation": "conceptually_related_to", "confidence": 